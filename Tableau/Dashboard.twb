        <calculation class='tableau' formula='[OrderQuantity] * [ProductPrice]' />
      </column>
      <column caption='Total Profit' datatype='real' default-format='C1033%' name='[Calculation_0080559404384257]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[OrderQuantity] * ([ProductPrice] - [ProductCost])' />
      </column>
      <column caption='Total Order' datatype='integer' name='[Calculation_0080559405219842]' role='measure' type='quantitative'>
