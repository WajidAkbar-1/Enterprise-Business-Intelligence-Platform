    <worksheet name='Sheet 2'>
      <layout-options>
        <title>
          <formatted-text>
            <run bold='true' fontsize='16'>Total Profit</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Merge All Table (Cleaning Datasets)' name='federated.1aws9jr1iyr5lv11f7j1b1no7b1o' />
          </datasources>
          <datasource-dependencies datasource='federated.1aws9jr1iyr5lv11f7j1b1no7b1o'>
            <column caption='Total Profit' datatype='real' default-format='C1033%' name='[Calculation_0080559404384257]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[OrderQuantity] * ([ProductPrice] - [ProductCost])' />
            </column>
            <column caption='Order Quantity' datatype='integer' name='[OrderQuantity]' role='measure' type='quantitative' />
            <column caption='Product Cost' datatype='real' name='[ProductCost]' role='measure' type='quantitative' />
            <column caption='Product Price' datatype='real' default-format='C1033%' name='[ProductPrice]' role='measure' type='quantitative' />
            <column-instance column='[Calculation_0080559404384257]' derivation='Sum' name='[sum:Calculation_0080559404384257:qk]' pivot='key' type='quantitative' />
          </datasource-dependencies>
          <aggregation value='true' />
